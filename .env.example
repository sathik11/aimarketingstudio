# Local configuration for managed identity based auth.
# Do not place access keys or connection strings here.

# Azure OpenAI endpoint and deployment.
AZURE_OPENAI_ENDPOINT=https://<your-openai-resource>.openai.azure.com/openai/v1/
AZURE_OPENAI_DEPLOYMENT=gpt-5.4

# Speech service configuration for SpeechSynthesizer with Entra auth.
# Use the Azure resource ID of the Speech or AI Services resource and its region.
AZURE_SPEECH_RESOURCE_ID=/subscriptions/<subscription-id>/resourceGroups/<resource-group>/providers/Microsoft.CognitiveServices/accounts/<speech-resource-name>
AZURE_SPEECH_REGION=<region>
AZURE_SPEECH_VOICE=fil-PH-BlessicaNeural

# Blob Storage account URL and container name.
# Optional in local development. If set, upload is attempted after the local WAV is created.
AZURE_STORAGE_ACCOUNT_URL=https://agents1allproject1data.blob.core.windows.net
AZURE_STORAGE_CONTAINER_NAME=taglish

# Local audio folder served by the Flask app for browser playback.
LOCAL_AUDIO_OUTPUT_DIR=generated_audio

# Optional for local development if selecting a specific identity.
# AZURE_TENANT_ID=<tenant-id>
# AZURE_CLIENT_ID=<user-assigned-managed-identity-client-id>
